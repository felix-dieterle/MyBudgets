<?xml version="1.0" encoding="utf-8"?>
<!--
    Network security configuration for MyBudgets.

    FinTS/HBCI communication uses HTTPS exclusively for modern banks (FinTS 3.0+).
    Some legacy bank servers may still use older TLS configurations.
    This config trusts the system CA store (default behavior) and allows
    debug builds to use cleartext for local backend development only.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>

    <!-- Allow cleartext only in debug builds for local backend (e.g. http://192.168.x.x) -->
    <debug-overrides>
        <trust-anchors>
            <certificates src="system" />
            <certificates src="user" />
        </trust-anchors>
    </debug-overrides>
</network-security-config>
